# Required bunq credentials
BUNQ_API_KEY=replace-with-your-api-key

# bunq API target (prod or sandbox)
BUNQ_API_BASE_URL=https://api.bunq.com/v1

# Server behavior
NODE_ENV=production
LOG_LEVEL=info
MCP_SERVER_NAME=bunq-business-mcp
MCP_SERVER_VERSION=0.1.0

# bunq context + sqlite state
SQLITE_PATH=./data/bunq-mcp.sqlite
BUNQ_CONTEXT_PATH=./data/bunq-context.json
BUNQ_DEVICE_DESCRIPTION=bunq-mcp-server

# bunq headers
BUNQ_USER_AGENT=bunq-mcp-server/0.1.0
BUNQ_LANGUAGE=en_US
BUNQ_REGION=en_US
BUNQ_GEOLOCATION=0 0 0 0 NL
# BUNQ_PERMITTED_IPS=203.0.113.10,2001:db8::10

# Safety switches
ENABLE_PAYMENTS=false
ENABLE_DRAFT_PAYMENTS=false

# Webhook receiver
WEBHOOK_ENABLED=true
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8787
WEBHOOK_PATH=/webhook/bunq
WEBHOOK_SHARED_SECRET=change-me

# Matching defaults
DEFAULT_TRANSACTION_PAGE_SIZE=100
DEFAULT_RECONCILIATION_DATE_WINDOW_DAYS=14
DEFAULT_RECONCILIATION_AMOUNT_TOLERANCE=0.01
DEFAULT_CURRENCY=EUR
